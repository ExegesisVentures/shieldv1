# ========================================
# ShieldNest Environment Configuration
# ========================================
# Copy this file to .env.local and fill in your actual values
# Command: cp env.template .env.local

# ========================================
# SUPABASE (REQUIRED)
# ========================================
# Get these from: https://app.supabase.com/project/_/settings/api

# Your Supabase project URL
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co

# Your Supabase anon/public key (safe to expose in browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_ANON_KEY

# Your Supabase service role key (NEVER expose in browser, server-only!)
# Used for admin operations that bypass Row Level Security (RLS)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.YOUR_SERVICE_ROLE_KEY

# ========================================
# UPDATE.DEV (REQUIRED for billing/subscriptions)
# ========================================
# Get this from: https://update.dev/dashboard

NEXT_PUBLIC_UPDATE_PUBLISHABLE_KEY=pk_update_YOUR_KEY

# ========================================
# COREUM BLOCKCHAIN (OPTIONAL - has defaults)
# ========================================
# Only override if you want to use testnet or custom endpoints

# Coreum RPC endpoint (defaults to mainnet if not set)
# NEXT_PUBLIC_COREUM_RPC=https://full-node.mainnet-1.coreum.dev:26657

# Coreum REST endpoint (defaults to mainnet if not set)
# NEXT_PUBLIC_COREUM_REST=https://full-node.mainnet-1.coreum.dev:1317

# CoreDEX API endpoint (production or self-hosted)
# If using Vite-style envs, you can set:
# VITE_ENV_BASE_API=https://coredexapi.shieldnest.org/api
# VITE_ENV_WS=wss://coredexapi.shieldnest.org/api/ws
# Otherwise, for Next.js style:
# NEXT_PUBLIC_COREDEX_API=https://coredexapi.shieldnest.org/api

# ========================================
# COINGECKO (OPTIONAL - for price fallback)
# ========================================
# CoinGecko API key for fetching token prices as fallback
# Get free API key from: https://www.coingecko.com/en/api/pricing
# Without this, app will use last cached prices or static fallback
# NEXT_PUBLIC_COINGECKO_API_KEY=CG-YOUR-API-KEY-HERE

# ========================================
# SITE URL (OPTIONAL for local development)
# ========================================
# Used for absolute URLs in auth redirects
# NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ========================================
# ADMIN CONFIGURATION (REQUIRED for admin features)
# ========================================
# Admin wallet addresses (comma-separated, lowercase)
# Example: core1xxx,core1yyy,core1zzz
ADMIN_WALLET_ADDRESSES=core1mgvlgvh2hfw5pgdqc79up3du69v2z3t8qz4kwg,core1jcas459gnu857ylephjdjlea3rkr38m0asj6gw,core1ltltw0jya4hq39myd9798qqvu6jzy6zxalxhqu

# Admin email addresses (comma-separated)
# Example: admin1@example.com,admin2@example.com
ADMIN_EMAILS=nestd@pm.me

# ========================================
# VERCEL (Auto-set in production, optional locally)
# ========================================
# VERCEL_URL is automatically set by Vercel in deployed environments
# You don't need to set this manually
